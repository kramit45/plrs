              "pm.environment.set('newTopicId', pm.response.json().id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{instructorAccessToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"{{newTopicName}}\",\n  \"description\": \"Iter 3 Newman E2E\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/topics",
          "host": ["{{baseUrl}}"],
          "path": ["api", "topics"]
        }
      }
    },
