    {
      "name": "Admin triggers recommender recompute",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('status is OK', () => pm.expect(pm.response.json().status).to.eql('OK'));"
            ]
          }
        }
